# =============================================================================
# PROPOSAR — Environment Variables (Paddle billing)
# =============================================================================
# Copy to .env.local and fill in your values. Never commit .env.local.
# =============================================================================

# Supabase (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI (proposal/contract generation)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=openai

# Paddle (Billing — Dashboard: https://vendors.paddle.com)
# API key: Developer Tools > Authentication > API keys
# Webhook secret: Developer Tools > Notifications > your destination > Secret key
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
# Optional: override price IDs (defaults are in lib/paddle.ts)
# PADDLE_STARTER_PRICE_ID=pri_xxx
# PADDLE_PRO_PRICE_ID=pri_xxx
# PADDLE_AGENCY_PRICE_ID=pri_xxx

# Resend (email)
RESEND_API_KEY=

# Upstash Redis (optional) - OTP stored here instead of Supabase until auth completes
# Add Redis from Vercel Marketplace; or use UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
KV_REST_API_URL=
KV_REST_API_TOKEN=
RESEND_FROM_EMAIL=hello@yourdomain.com

# Contact form (optional)
CONTACT_EMAIL=support@yourdomain.com

# Cron (optional; for follow-up emails)
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Proposar

# PostHog (analytics — see docs/POSTHOG_ACCESS.md)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
