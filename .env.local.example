# =============================================================================
# PROPOSAR - Environment Variables Reference
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local - it contains secrets.
# =============================================================================

# Supabase (get from Dashboard > Settings > API)
# Use project URL: https://<project-ref>.supabase.co (NOT the dashboard URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI (for proposal, contract, follow-up generation)
# AI_PROVIDER: "openai" or "anthropic"
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=openai

# Paddle (Payments)
# Get from Paddle Dashboard: API keys, Product IDs (price IDs), Webhook secret
PADDLE_API_KEY=pdl_live_apikey_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_xxxxxxxxxxxxxxxxxxxxxxx
PADDLE_WEBHOOK_SECRET=whk_live_xxxxxxxxxxxxxxxxxxxxxxx

# Resend (email - proposals, follow-ups, contact form)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@yourdomain.com

# Contact form (optional - defaults to support@proposar.com)
CONTACT_EMAIL=support@yourdomain.com

# Cron (optional - for scheduled follow-up emails & expiring proposals)
# Add CRON_SECRET if you use Vercel Cron or external cron
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Proposar
