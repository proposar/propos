{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "recall-context",
  "title": "Recall Context",
  "description": "Machine-readable project context so any AI can read/update without re-scanning the whole repo",
  "type": "object",
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "projectName": { "type": "string" },
    "oneLiner": { "type": "string" },
    "stack": {
      "type": "array",
      "items": { "type": "string" }
    },
    "currentFocus": { "type": "string" },
    "pendingTasks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "keyPaths": {
      "type": "object",
      "description": "Important paths; AI should read these when relevant",
      "additionalProperties": { "type": "string" }
    },
    "rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "lastUpdated": { "type": "string", "format": "date-time" },
    "lastUpdatedBy": { "type": "string" },
    "recentChanges": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "properties": {
          "at": { "type": "string", "format": "date-time" },
          "what": { "type": "string" }
        }
      }
    },
    "snapshot": {
      "type": "object",
      "description": "Generated by generate-snapshot; do not edit by hand",
      "properties": {
        "generatedAt": { "type": "string", "format": "date-time" },
        "keyDirs": { "type": "array", "items": { "type": "string" } },
        "keyFiles": { "type": "array", "items": { "type": "string" } },
        "recentCommits": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "required": [ "version", "projectName", "oneLiner", "lastUpdated" ]
}
